<?xml version="1.0" ?>
<testsuite name="">
	<testsuite name="Fluxo de criação">
		<testcase name="Criar usuário com dados válidos">
			<summary>
				<!-- -->
<![CDATA[Verificar se o usuário é criado com sucesso no banco de dados<br />
[PRECONDITIONS]<br />
O usuário deve estar logado como administrador.]]>				<!-- -->
			</summary>
			<preconditions/>
			<execution_type>1</execution_type>
			<importance>3</importance>
			<steps>
				<step>
					<actions>
						<!-- -->
<![CDATA[Acessar tela de cadastro]]>						<!-- -->
					</actions>
					<expectedresults>
						<!-- -->
<![CDATA[Tela de cadastro deve ser exibida]]>						<!-- -->
					</expectedresults>
					<execution_type>1</execution_type>
					<step_number>1</step_number>
				</step>
				<step>
					<actions>
						<!-- -->
<![CDATA[Preencher todos os campos obrigatórios]]>						<!-- -->
					</actions>
					<expectedresults>
						<!-- -->
<![CDATA[Campos devem aceitar os dado]]>						<!-- -->
					</expectedresults>
					<execution_type>1</execution_type>
					<step_number>2</step_number>
				</step>
				<step>
					<actions>
						<!-- -->
<![CDATA[Clicar em "Salvar"]]>						<!-- -->
					</actions>
					<expectedresults>
						<!-- -->
<![CDATA[Mensagem de sucesso deve ser exibida]]>						<!-- -->
					</expectedresults>
					<execution_type>1</execution_type>
					<step_number>3</step_number>
				</step>
				<step>
					<actions>
						<!-- -->
<![CDATA[Validar no banco de dados]]>						<!-- -->
					</actions>
					<expectedresults>
						<!-- -->
<![CDATA[O registro do usuário deve existir na tabela 'users']]>						<!-- -->
					</expectedresults>
					<execution_type>1</execution_type>
					<step_number>4</step_number>
				</step>
			</steps>
		</testcase>
		<testcase name="Tentativa de criação com e-mail duplicado">
			<summary>
				<!-- -->
<![CDATA[O sistema deve impedir a criação de usuários com e-mail já cadastrado.<br />
[PRECONDITIONS]<br />
Deve existir um usuário com o e-mail cadastrado.<br />
O usuário deve estar logado como administrador.]]>				<!-- -->
			</summary>
			<preconditions/>
			<execution_type>1</execution_type>
			<importance>2</importance>
			<steps>
				<step>
					<actions>
						<!-- -->
<![CDATA[Preencher e-mail já existente]]>						<!-- -->
					</actions>
					<expectedresults>
						<!-- -->
<![CDATA[O campo e-mail deve exibir um erro de validação]]>						<!-- -->
					</expectedresults>
					<execution_type>1</execution_type>
					<step_number>1</step_number>
				</step>
				<step>
					<actions>
						<!-- -->
<![CDATA[Clicar em "Salvar"]]>						<!-- -->
					</actions>
					<expectedresults>
						<!-- -->
<![CDATA[O usuário não deve ser criado e a mensagem de erro deve persistir]]>						<!-- -->
					</expectedresults>
					<execution_type>1</execution_type>
					<step_number>2</step_number>
				</step>
			</steps>
		</testcase>
	</testsuite>
</testsuite>
